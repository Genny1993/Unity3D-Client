  m_text: "\u0421\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0446\u0438\u0442\u0438\u0440\u0443\u0435\u043C\u043E\u0433\u043E
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F, \u043E\u043D\u043E
    \u043E\u0447\u0435\u043D\u044C \u043E\u0447\u0435\u043D\u044C \u043E\u0447\u0435\u043D\u044C
